{
  "name": "openai-realtime-voice-agent",
  "version": "1.0.0",
  "description": "Voice agent implementation using OpenAI Realtime API with WebRTC",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:all": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start_all.ps1",
    "dev": "nodemon server.js",
    "worker": "node embeddingsWorker.js",
    "deploy": "docker build -t voice-agent .",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "build": " npx webpack --config webpack.config.cjs"
  },
  "keywords": [
    "openai",
    "realtime",
    "voice-agent",
    "webrtc",
    "ai"
  ],
  "author": "Voice Agent Developer",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.8",
    "axios-retry": "^3.9.1",
    "bullmq": "^5.6.0",
    "chart.js": "^4.4.0",
    "convict": "^6.2.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "node-cache": "^5.1.2",
    "openai": "^4.52.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.16.3",
    "pgvector": "^0.2.1",
    "pino": "^8.16.1",
    "redis": "^4.6.7"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@jest/globals": "^30.0.5",
    "assert": "^2.1.0",
    "babel-loader": "^10.0.0",
    "browserify-zlib": "^0.2.0",
    "buffer": "^6.0.3",
    "constants-browserify": "^1.0.0",
    "crypto-browserify": "^3.12.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "os-browserify": "^0.3.0",
    "path-browserify": "^1.0.1",
    "process": "^0.11.10",
    "querystring-es3": "^0.2.1",
    "stream-browserify": "^3.0.0",
    "supertest": "^6.3.4",
    "url": "^0.11.4",
    "util": "^0.12.5",
    "vm-browserify": "^1.1.2",
    "webpack": "^5.101.0",
    "webpack-cli": "^6.0.1"
  }
